{
  "name": "clio-extractor",
  "version": "1.0.8",
  "description": "A helper app to fetch data from Clio API and compile in reports",
  "main": "./out/main/index.js",
  "author": "Muhammad Talha",
  "homepage": "https://github.com/zaheertalha123/c1i0-3xtr4ct0r-r3134s3s#readme",
  "repository": "zaheertalha123/c1i0-3xtr4ct0r-r3134s3s",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "npm run build && electron-builder --dir",
    "icon:convert": "node scripts/convert-icon.js",
    "env:encrypt": "node scripts/encrypt-env.js",
    "build:win": "npm run icon:convert && npm run env:encrypt && npm run build && electron-builder --win",
    "build:mac": "npm run env:encrypt && npm run build && electron-builder --mac",
    "build:linux": "npm run env:encrypt && npm run build && electron-builder --linux"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "dotenv": "^17.3.1",
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@types/node": "^22.19.1",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "png-to-ico": "^3.0.1",
    "prettier": "^3.7.4",
    "typescript": "^5.9.3",
    "vite": "^7.2.6"
  }
}
